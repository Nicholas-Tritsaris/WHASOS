# WHAOS Kernel Default Config (minimal set for VirtualBox)
# Merge with: make defconfig && apply these overrides

# Essential
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4

# VirtualBox storage
CONFIG_ATA_PIIX=y
CONFIG_ATA_SFF=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y
CONFIG_EXT4_FS=y

# VirtualBox graphics (VMSVGA / VESA fallback)
CONFIG_DRM=y
CONFIG_DRM_VMWGFX=y
CONFIG_DRM_BOCHS=y
CONFIG_FB=y
CONFIG_FB_VESA=y

# Input
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_KEYBOARD_ATKBD=y
CONFIG_MOUSE_PS2=y

# Network (Intel PRO/1000)
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000=y
CONFIG_E1000E=y

# File systems
CONFIG_EXT4_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y

# Misc
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_PRINTK=y
